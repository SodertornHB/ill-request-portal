@* --------------------------------------------------------------------*@
@* Warning! This is an auto generated file. Changes may be overwritten *@
@* --------------------------------------------------------------------*@
@using Localization
@inject LocService SharedLocalizer
@model IEnumerable<IllRequestPortal.Web.ViewModel.IllRequestViewModel>

@{
    ViewData["Title"] = $"{SharedLocalizer.GetLocalizedHtmlString("List")} {SharedLocalizer.GetLocalizedHtmlString("IllRequest")}";
}

<h1>@SharedLocalizer.GetLocalizedHtmlString("IllRequest")</h1>

<a asp-controller="IllRequest" asp-action="Create">
    <button type="button" class="btn btn-info btn-lg"><span class="bi bi-plus-circle"></span>@SharedLocalizer.GetLocalizedHtmlString("Create New")</button>
</a>
<hr />
<table class="table table-striped table-sm data-table ill-table">
    <thead>
        <tr>
            <th></th>
            <th>
                @SharedLocalizer.GetLocalizedHtmlString("Status")
            </th>
            <th>
                @SharedLocalizer.GetLocalizedHtmlString("CreatedOn")
            </th>
            <th class="tooltip-r" title="@SharedLocalizer.GetLocalizedHtmlString("TitleTooltip")">
                @SharedLocalizer.GetLocalizedHtmlString("Title")
            </th>
            <th class="tooltip-r" title="@SharedLocalizer.GetLocalizedHtmlString("TitleAuthorTooltip")">
                @SharedLocalizer.GetLocalizedHtmlString("Author")
            </th>
            <th class="tooltip-r" title="@SharedLocalizer.GetLocalizedHtmlString("ArticleTitleTooltip")">
                @SharedLocalizer.GetLocalizedHtmlString("ArticleTitle")
            </th>
            <th class="tooltip-r" title="@SharedLocalizer.GetLocalizedHtmlString("ArticleAuthorTooltip")">
                @SharedLocalizer.GetLocalizedHtmlString("ArticleAuthor")
            </th>
            <th>
                @SharedLocalizer.GetLocalizedHtmlString("PublicationYear")
            </th>
            <th>
                @SharedLocalizer.GetLocalizedHtmlString("Isbn")
            </th>
            <th>
                @SharedLocalizer.GetLocalizedHtmlString("Issn")
            </th>
            <th>
                @SharedLocalizer.GetLocalizedHtmlString("MaterialType")
            </th>
            <th>
                @SharedLocalizer.GetLocalizedHtmlString("RequesterName")
            </th>
            <th>
                @SharedLocalizer.GetLocalizedHtmlString("RequesterEmail")
            </th>
            <th>
                @SharedLocalizer.GetLocalizedHtmlString("CardNumber")
            </th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td class="ill-actions">

                    <a asp-controller="IllRequest"
                       asp-action="Edit"
                       asp-route-id="@item.Id"
                       class="btn btn-sm btn-outline-primary icon-btn tooltip-r"
                       data-toggle="tooltip"
                       title="@item.Description">
                        <i class="bi bi-pencil"></i>
                    </a>

                    <a asp-controller="IllRequest"
                       asp-action="Remove"
                       asp-route-id="@item.Id"
                       class="btn btn-sm btn-outline-danger icon-btn tooltip-r"
                       data-toggle="tooltip"
                       title="@SharedLocalizer.GetLocalizedHtmlString("Delete")">
                        <i class="bi bi-trash"></i>
                    </a>

                    @if (!string.IsNullOrEmpty(item.KohaUrl))
                    {
                        <a href="@item.KohaUrl"
                           target="_blank"
                           class="btn btn-sm btn-outline-secondary icon-btn tooltip-r"
                           data-toggle="tooltip"
                           title="@SharedLocalizer.GetLocalizedHtmlString("KohaRecord")">
                            <i class="bi bi-book"></i>
                        </a>
                    }

                    @if (!string.IsNullOrEmpty(item.LibrisUrl))
                    {
                        <a href="@item.LibrisUrl"
                           target="_blank"
                           class="btn btn-sm btn-outline-secondary icon-btn tooltip-r"
                           data-toggle="tooltip"
                           title="@SharedLocalizer.GetLocalizedHtmlString("LibrisRecord")">
                            <i class="bi bi-search"></i>
                        </a>
                    }

                </td>
                <td class="tooltip-r" data-toggle="tooltip" data-placement="left" title="@item.Status">

                    <select class="status-select form-control form-control-sm"
                            data-request-id="@item.Id">

                        <option value="Registered" selected="@(item.Status == "Registered")">
                            @SharedLocalizer.GetLocalizedHtmlString("Registered")
                        </option>

                        <option value="UnderArbete" selected="@(item.Status == "UnderArbete")">
                            @SharedLocalizer.GetLocalizedHtmlString("UnderArbete")
                        </option>

                        <option value="OrderedInLibris" selected="@(item.Status == "OrderedInLibris")">
                            @SharedLocalizer.GetLocalizedHtmlString("OrderedInLibris")
                        </option>

                        <option value="Purchased" selected="@(item.Status == "Purchased")">
                            @SharedLocalizer.GetLocalizedHtmlString("Purchased")
                        </option>

                        <option value="Rejected" selected="@(item.Status == "Rejected")">
                            @SharedLocalizer.GetLocalizedHtmlString("Rejected")
                        </option>

                    </select>

                </td>
                <td class="tooltip-r" data-toggle="tooltip" data-placement="left" title="@(item.CreatedOn?.ToString("yyyy-MM-dd HH:mm"))">
                    @(item.CreatedOn?.ToString("yyyy-MM-dd"))
                </td>
                <td class="truncate tooltip-r" data-toggle="tooltip" data-placement="left" title="@item.Title">
                    @item.Title
                </td>
                <td class="truncate tooltip-r" data-toggle="tooltip" data-placement="left" title="@item.Author">
                    @item.Author
                </td>
                <td class="truncate tooltip-r" data-toggle="tooltip" data-placement="left" title="@item.ArticleTitle">
                    @item.ArticleTitle
                </td>
                <td class="truncate tooltip-r" data-toggle="tooltip" data-placement="left" title="@item.ArticleAuthor">
                    @item.ArticleAuthor
                </td>
                <td class="tooltip-r" data-toggle="tooltip" data-placement="left" title="@item.PublicationYear">
                    @item.PublicationYear
                </td>
                <td class="tooltip-r" data-toggle="tooltip" data-placement="left" title="@item.Isbn">
                    @item.Isbn
                </td>
                <td class="tooltip-r" data-toggle="tooltip" data-placement="left" title="@item.Issn">
                    @item.Issn
                </td>
                <td class="tooltip-r" data-toggle="tooltip" data-placement="left" title="@item.MaterialType">
                    @SharedLocalizer.GetLocalizedHtmlString(item.MaterialType)
                </td>
                <td class="tooltip-r" data-toggle="tooltip" data-placement="left" title="@item.RequesterName">
                    @item.RequesterName
                </td>
                <td class="tooltip-r" data-toggle="tooltip" data-placement="left" title="@item.RequesterEmail">
                    @Html.Raw(item.EmailWithLink())
                </td>
                <td class="tooltip-r" data-toggle="tooltip" data-placement="left" title="@item.CardNumber">
                    @item.CardNumber
                </td>
            </tr>
        }
    </tbody>
</table>
