@using IllRequestPortal.Logic.Settings
@using Localization
@using Microsoft.Extensions.Options
@using System.Text.Json
@inject IOptions<DiscoverySettings> DiscoverySettings
@inject LocService SharedLocalizer
@model IllRequestPortal.Web.ViewModel.CreateIllRequestViewModel

@{
    ViewData["Title"] = $"{SharedLocalizer.GetLocalizedHtmlString("Create IllRequest")}";
}

<h1>@($"{SharedLocalizer.GetLocalizedHtmlString("Create IllRequest")}")</h1>

<hr />
<div class="row">
    <div class="col-lg-8 col-xl-7">
        <form method="post" enctype="multipart/form-data" asp-controller="IllRequest" asp-action="Create">
            @if (ViewBag.Message != null || ViewBag.Error != null || !ViewData.ModelState.IsValid)
            {
                <div class="ill-feedback">
                    <div asp-validation-summary="ModelOnly" class="text-danger"></div>

                    @if (ViewBag.Message != null)
                    {
                        <div class="alert alert-info mb-0">@ViewBag.Message</div>
                    }

                    @if (ViewBag.Error != null)
                    {
                        <div class="alert alert-danger mb-0">@ViewBag.Error</div>
                    }
                </div>
            }

            <div class="ill-section">

                <div class="ill-section-title">@SharedLocalizer.GetLocalizedHtmlString("BibliographicLookup")</div>
                <div class="ill-helper-text">@SharedLocalizer.GetLocalizedHtmlString("EnterMatrialTypeAndIsbnIssnFirst")</div>
                <div class="form-group">
                    <label asp-for="MaterialType" class="control-label">@SharedLocalizer.GetLocalizedHtmlString("MaterialType")</label>
                    <select asp-for="MaterialType" class="form-control" id="materialTypeSelect">
                        <option value=""></option>
                        <option value="Book">@SharedLocalizer.GetLocalizedHtmlString("Book")</option>
                        <option value="Article">@SharedLocalizer.GetLocalizedHtmlString("Article")</option>
                        <option value="Chapter">@SharedLocalizer.GetLocalizedHtmlString("Chapter")</option>
                    </select>
                    <span asp-validation-for="MaterialType" class="text-danger"></span>
                </div>

                <div class="form-group field-book field-chapter">
                    <label asp-for="Isbn" class="control-label">@SharedLocalizer.GetLocalizedHtmlString("Isbn")</label>
                    <div class="lookup-row">
                        <input asp-for="Isbn" class="form-control lookup-input" />
                        <span id="bibliographicLookupSpinner" class="loading-spinner hidden"></span>
                    </div>
                    <span asp-validation-for="Isbn" class="text-danger"></span>
                </div>

                <div class="form-group field-article">
                    <label asp-for="Issn" class="control-label">@SharedLocalizer.GetLocalizedHtmlString("Issn")</label>
                    <input asp-for="Issn" class="form-control" />
                    <span asp-validation-for="Issn" class="text-danger"></span>
                </div>

                <div id="bibliographicLookupStatus" class="lookup-status-panel lookup-status-neutral hidden"></div>
            </div>

            <div class="ill-section">
                <div class="ill-section-title">@SharedLocalizer.GetLocalizedHtmlString("RequestInformation")</div>

                <div class="form-group field-book">
                    <label asp-for="BookTitle" class="control-label">@SharedLocalizer.GetLocalizedHtmlString("BookTitle")</label>
                    <input asp-for="BookTitle" class="form-control" />
                    <span asp-validation-for="BookTitle" class="text-danger"></span>
                </div>

                <div class="form-group field-book">
                    <label asp-for="BookAuthor" class="control-label">@SharedLocalizer.GetLocalizedHtmlString("BookAuthor")</label>
                    <input asp-for="BookAuthor" class="form-control" />
                    <span asp-validation-for="BookAuthor" class="text-danger"></span>
                </div>

                <div class="form-group field-book">
                    <label asp-for="BookPublicationYear" class="control-label">@SharedLocalizer.GetLocalizedHtmlString("PublicationYear")</label>
                    <input asp-for="BookPublicationYear" class="form-control" />
                    <span asp-validation-for="BookPublicationYear" class="text-danger"></span>
                </div>

                <div class="form-group field-chapter">
                    <label asp-for="ChapterBookTitle" class="control-label">@SharedLocalizer.GetLocalizedHtmlString("BookTitle")</label>
                    <input asp-for="ChapterBookTitle" class="form-control" />
                    <span asp-validation-for="ChapterBookTitle" class="text-danger"></span>
                </div>

                <div class="form-group field-chapter">
                    <label asp-for="ChapterBookAuthor" class="control-label">@SharedLocalizer.GetLocalizedHtmlString("BookAuthor")</label>
                    <input asp-for="ChapterBookAuthor" class="form-control" />
                    <span asp-validation-for="ChapterBookAuthor" class="text-danger"></span>
                </div>

                <div class="form-group field-chapter">
                    <label asp-for="ChapterAuthor" class="control-label">@SharedLocalizer.GetLocalizedHtmlString("ChapterAuthor")</label>
                    <input asp-for="ChapterAuthor" class="form-control" />
                    <span asp-validation-for="ChapterAuthor" class="text-danger"></span>
                </div>

                <div class="form-group field-chapter">
                    <label asp-for="ChapterTitle" class="control-label">@SharedLocalizer.GetLocalizedHtmlString("ChapterTitle")</label>
                    <input asp-for="ChapterTitle" class="form-control" />
                    <span asp-validation-for="ChapterTitle" class="text-danger"></span>
                </div>

                <div class="form-row field-chapter">
                    <div class="form-group col-md-5">
                        <label asp-for="ChapterBookPublicationYear" class="control-label">@SharedLocalizer.GetLocalizedHtmlString("PublicationYear")</label>
                        <input asp-for="ChapterBookPublicationYear" class="form-control" />
                        <span asp-validation-for="ChapterBookPublicationYear" class="text-danger"></span>
                    </div>

                    <div class="form-group col-md-5">
                        <label asp-for="ChapterPages" class="control-label">@SharedLocalizer.GetLocalizedHtmlString("Pages")</label>
                        <input asp-for="ChapterPages" class="form-control" />
                        <span asp-validation-for="ChapterPages" class="text-danger"></span>
                    </div>
                </div>

                <div class="form-group field-article">
                    <label asp-for="JournalTitle" class="control-label">@SharedLocalizer.GetLocalizedHtmlString("JournalTitle")</label>
                    <input asp-for="JournalTitle" class="form-control containter-journal-title" />
                    <span asp-validation-for="JournalTitle" class="text-danger"></span>
                </div>

                <div class="form-group field-article">
                    <label asp-for="ArticleAuthor" class="control-label">@SharedLocalizer.GetLocalizedHtmlString("ArticleAuthor")</label>
                    <input asp-for="ArticleAuthor" class="form-control" />
                    <span asp-validation-for="ArticleAuthor" class="text-danger"></span>
                </div>

                <div class="form-group field-article">
                    <label asp-for="ArticleTitle" class="control-label">@SharedLocalizer.GetLocalizedHtmlString("ArticleTitle")</label>
                    <input asp-for="ArticleTitle" class="form-control" />
                    <span asp-validation-for="ArticleTitle" class="text-danger"></span>
                </div>


                <div class="form-row field-article">
                    <div class="form-group col-md-3">
                        <label asp-for="Volume" class="control-label">@SharedLocalizer.GetLocalizedHtmlString("Volume")</label>
                        <input asp-for="Volume" class="form-control" />
                        <span asp-validation-for="Volume" class="text-danger"></span>
                    </div>

                    <div class="form-group col-md-3">
                        <label asp-for="ArticlePublicationYear" class="control-label">@SharedLocalizer.GetLocalizedHtmlString("PublicationYear")</label>
                        <input asp-for="ArticlePublicationYear" class="form-control" />
                        <span asp-validation-for="ArticlePublicationYear" class="text-danger"></span>
                    </div>

                    <div class="form-group col-md-3">
                        <label asp-for="Issue" class="control-label">@SharedLocalizer.GetLocalizedHtmlString("Issue")</label>
                        <input asp-for="Issue" class="form-control" />
                        <span asp-validation-for="Issue" class="text-danger"></span>
                    </div>

                    <div class="form-group col-md-3">
                        <label asp-for="ArticlePages" class="control-label">@SharedLocalizer.GetLocalizedHtmlString("Pages")</label>
                        <input asp-for="ArticlePages" class="form-control" />
                        <span asp-validation-for="ArticlePages" class="text-danger"></span>
                    </div>
                </div>
            </div>

            <div class="ill-section">
                <div class="ill-section-title">@SharedLocalizer.GetLocalizedHtmlString("RequesterInformation")</div>


                <div class="form-group">
                    <label asp-for="CardNumber" class="control-label">@SharedLocalizer.GetLocalizedHtmlString("CardNumber")</label>
                    <div class="lookup-row">
                        <input asp-for="CardNumber"
                               class="form-control lookup-input"
                               maxlength="10"
                               inputmode="numeric"
                               pattern="\d{10}" />
                        <span id="patronLookupSpinner" class="loading-spinner hidden"></span>
                    </div>
                    <div id="patronLookupStatus" class="lookup-status-panel lookup-status-neutral hidden"></div>
                    <span asp-validation-for="CardNumber" class="text-danger"></span>
                </div>

                <div class="form-group">
                    <label asp-for="RequesterName" class="control-label">@SharedLocalizer.GetLocalizedHtmlString("RequesterName")</label>
                    <input asp-for="RequesterName" class="form-control" />
                    <span asp-validation-for="RequesterName" class="text-danger"></span>
                </div>

                <div class="form-group">
                    <label asp-for="RequesterEmail" class="control-label">@SharedLocalizer.GetLocalizedHtmlString("RequesterEmail")</label>
                    <input asp-for="RequesterEmail" class="form-control" />
                    <span asp-validation-for="RequesterEmail" class="text-danger"></span>
                </div>
            </div>

            <div class="form-group">
                <input type="submit" value="@SharedLocalizer.GetLocalizedHtmlString("Create")" class="btn btn-primary" />
            </div>
        </form>
    </div>
</div>

<script>
    window.illTexts = @Html.Raw(JsonSerializer.Serialize(new
        {
            foundInKohaMessage = SharedLocalizer.GetLocalizedHtmlString("FoundInKohaMessage").Value,
            foundInLibrisMessage = SharedLocalizer.GetLocalizedHtmlString("FoundInLibrisMessage").Value,
            kohaBorrowLinkText = SharedLocalizer.GetLocalizedHtmlString("KohaBorrowLinkText").Value,
            missingBiblioIdMessage = SharedLocalizer.GetLocalizedHtmlString("MissingBiblioIdMessage").Value,
            noBibliographicRecordFoundMessage = SharedLocalizer.GetLocalizedHtmlString("NoBibliographicRecordFoundMessage").Value,
            librarySystemErrorMessage = SharedLocalizer.GetLocalizedHtmlString("LibrarySystemErrorMessage").Value,
            noPatronFound = SharedLocalizer.GetLocalizedHtmlString("NoPatronFoundWithCardNumber").Value,
            patronFound = SharedLocalizer.GetLocalizedHtmlString("PatronFound").Value,
            lookingUpPatron = SharedLocalizer.GetLocalizedHtmlString("LookingUpPatron").Value,
            lookingUpBibliographicRecord = SharedLocalizer.GetLocalizedHtmlString("LookingUpBibliographicRecord").Value,
            discoveryRecordUrlTemplate = DiscoverySettings.Value.RecordUrlTemplate
        }));
</script>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}
