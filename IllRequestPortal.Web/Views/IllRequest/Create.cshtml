@using IllRequestPortal.Logic.Settings
@using Localization
@using Microsoft.Extensions.Options
@using System.Text.Json
@inject IOptions<DiscoverySettings> DiscoverySettings
@inject LocService SharedLocalizer
@model IllRequestPortal.Web.ViewModel.IllRequestViewModelExtended

@{
    ViewData["Title"] = $"{SharedLocalizer.GetLocalizedHtmlString("Create")} {SharedLocalizer.GetLocalizedHtmlString("IllRequest")}";
}

<h1>@($"{SharedLocalizer.GetLocalizedHtmlString("Create")} {@SharedLocalizer.GetLocalizedHtmlString("IllRequest")}")</h1>

<hr />

<div class="row">
    <div class="col-md-8">
        <form method="post" enctype="multipart/form-data" asp-controller="IllRequest" asp-action="Create">
            @if (ViewBag.Message != null || ViewBag.Error != null || !ViewData.ModelState.IsValid)
            {
                <div class="ill-feedback">
                    <div asp-validation-summary="ModelOnly" class="text-danger"></div>

                    @if (ViewBag.Message != null)
                    {
                        <div class="alert alert-info mb-0">@ViewBag.Message</div>
                    }

                    @if (ViewBag.Error != null)
                    {
                        <div class="alert alert-danger mb-0">@ViewBag.Error</div>
                    }
                </div>
            }

            <div class="ill-section">
                <div class="ill-section-title">@SharedLocalizer.GetLocalizedHtmlString("BibliographicLookup")</div>
                <div class="ill-helper-text">@SharedLocalizer.GetLocalizedHtmlString("EnterIsbnIssnFirst")</div>

                <div class="form-group">
                    <label asp-for="IsbnIssn" class="control-label">@SharedLocalizer.GetLocalizedHtmlString("IsbnIssn")</label>
                    <div>
                        <input asp-for="IsbnIssn" class="form-control" />
                        <span id="bibliographicLookupSpinner" class="loading-spinner hidden"></span>
                    </div>
                    <div id="bibliographicLookupStatus" class="text-muted small mt-1"></div>
                    <span asp-validation-for="IsbnIssn" class="text-danger"></span>
                </div>
                <div class="ill-section">
                    <div class="ill-section-title">@SharedLocalizer.GetLocalizedHtmlString("RequestInformation")</div>

                    <div class="form-group">
                        <label asp-for="Title" class="control-label">@SharedLocalizer.GetLocalizedHtmlString("Title")</label>
                        <input asp-for="Title" class="form-control" />
                        <span asp-validation-for="Title" class="text-danger"></span>
                    </div>

                    <div class="form-group">
                        <label asp-for="Author" class="control-label">@SharedLocalizer.GetLocalizedHtmlString("Author")</label>
                        <input asp-for="Author" class="form-control" />
                        <span asp-validation-for="Author" class="text-danger"></span>
                    </div>

                    <div class="form-group">
                        <label asp-for="PublicationYear" class="control-label">@SharedLocalizer.GetLocalizedHtmlString("PublicationYear")</label>
                        <input asp-for="PublicationYear" class="form-control" />
                        <span asp-validation-for="PublicationYear" class="text-danger"></span>
                    </div>

                    <div class="form-group">
                        <label asp-for="Edition" class="control-label">@SharedLocalizer.GetLocalizedHtmlString("Edition")</label>
                        <input asp-for="Edition" class="form-control" />
                        <span asp-validation-for="Edition" class="text-danger"></span>
                    </div>

                    <div class="form-group">
                        <label asp-for="MaterialType" class="control-label">@SharedLocalizer.GetLocalizedHtmlString("MaterialType")</label>
                        <select asp-for="MaterialType" class="form-control">
                            <option selected value="Book">@SharedLocalizer.GetLocalizedHtmlString("Book")</option>
                            <option value="Article">@SharedLocalizer.GetLocalizedHtmlString("Article")</option>
                            <option value="Chapter">@SharedLocalizer.GetLocalizedHtmlString("Chapter")</option>
                            <option value="Journal">@SharedLocalizer.GetLocalizedHtmlString("Journal")</option>
                            <option value="Other">@SharedLocalizer.GetLocalizedHtmlString("Other")</option>
                        </select>
                        <span asp-validation-for="MaterialType" class="text-danger"></span>
                    </div>

                    <div class="form-group">
                        <label asp-for="RequestType" class="control-label">@SharedLocalizer.GetLocalizedHtmlString("RequestType")</label>
                        <select asp-for="RequestType" class="form-control">
                            <option selected value="Loan">@SharedLocalizer.GetLocalizedHtmlString("Loan")</option>
                            <option value="Copy">@SharedLocalizer.GetLocalizedHtmlString("Copy")</option>
                        </select>
                        <span asp-validation-for="RequestType" class="text-danger"></span>
                    </div>
                </div>

                <div class="ill-section">
                    <div class="ill-section-title">@SharedLocalizer.GetLocalizedHtmlString("RequesterInformation")</div>
                    <div class="ill-helper-text">@SharedLocalizer.GetLocalizedHtmlString("EnterCardNumberFirst")</div>

                    <div class="form-group">
                        <label asp-for="CardNumber" class="control-label">@SharedLocalizer.GetLocalizedHtmlString("CardNumber")</label>
                        <div class="lookup-row">
                            <input asp-for="CardNumber" class="form-control lookup-input"
                                   maxlength="10"
                                   inputmode="numeric"
                                   required />
                            <span id="patronLookupSpinner" class="loading-spinner hidden"></span>
                        </div>
                        <div id="patronLookupStatus" class="text-muted small mt-1"></div>
                        <span asp-validation-for="CardNumber" class="text-danger"></span>
                    </div>

                    <div class="form-group">
                        <label asp-for="RequesterName" class="control-label">@SharedLocalizer.GetLocalizedHtmlString("RequesterName")</label>
                        <input asp-for="RequesterName" class="form-control" />
                        <span asp-validation-for="RequesterName" class="text-danger"></span>
                    </div>

                    <div class="form-group">
                        <label asp-for="RequesterEmail" class="control-label">@SharedLocalizer.GetLocalizedHtmlString("RequesterEmail")</label>
                        <input asp-for="RequesterEmail" class="form-control" />
                        <span asp-validation-for="RequesterEmail" class="text-danger"></span>
                    </div>
                </div>

                <div class="form-group">
                    <input type="submit" value="@SharedLocalizer.GetLocalizedHtmlString("Create")" class="btn btn-primary" />
                </div>
        </form>
    </div>
</div>

<script>
    window.illTexts = @Html.Raw(JsonSerializer.Serialize(new
        {
            foundInKohaMessage = SharedLocalizer.GetLocalizedHtmlString("FoundInKohaMessage").Value,
            foundInLibrisMessage = SharedLocalizer.GetLocalizedHtmlString("FoundInLibrisMessage").Value,
            kohaBorrowLinkText = SharedLocalizer.GetLocalizedHtmlString("KohaBorrowLinkText").Value,
            missingBiblioIdMessage = SharedLocalizer.GetLocalizedHtmlString("MissingBiblioIdMessage").Value,
            noPatronFound = SharedLocalizer.GetLocalizedHtmlString("NoPatronFoundWithCardNumber").Value,
            patronFound = SharedLocalizer.GetLocalizedHtmlString("PatronFound").Value,
            lookingUpPatron = SharedLocalizer.GetLocalizedHtmlString("LookingUpPatron").Value,
            lookingUpBibliographicRecord = SharedLocalizer.GetLocalizedHtmlString("LookingUpBibliographicRecord").Value,
            discoveryRecordUrlTemplate = DiscoverySettings.Value.RecordUrlTemplate
        }));
</script>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}
